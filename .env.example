# ─────────────────────────────────────────────────────────
# Database (Neon Postgres or any PostgreSQL)
# ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─────────────────────────────────────────────────────────
# Privy — Web3 + Twitter OAuth
# Get yours at https://privy.io
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# ─────────────────────────────────────────────────────────
# Helius — Solana RPC + transaction indexing
# Get yours at https://helius.dev
# ─────────────────────────────────────────────────────────
HELIUS_API_KEY="your-helius-api-key"

# ─────────────────────────────────────────────────────────
# Ponzinomics SDK — gamification + identity layer
# Get yours at https://ponzinomics.io (or contact the team)
# ─────────────────────────────────────────────────────────
PONZINOMICS_API_KEY="your-ponzinomics-api-key"
PONZINOMICS_PROJECT_ID="your-project-id"
PONZINOMICS_BASE_URL="https://api.sypher.io"   # optional, defaults to this

# ─────────────────────────────────────────────────────────
# Redis — caching layer (optional, app degrades gracefully)
# ─────────────────────────────────────────────────────────
REDIS_URL="redis://default:password@host:6379"

# ─────────────────────────────────────────────────────────
# Dune Analytics — on-chain deployer stats
# Get API key at https://dune.com/settings/api
# Fork the query or use ID 6183649
# ─────────────────────────────────────────────────────────
DUNE_API_KEY="your-dune-api-key"
DUNE_DEPLOYER_QUERY_ID="6183649"

# ─────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
JWT_SECRET="generate-a-random-32-char-string"

# ─────────────────────────────────────────────────────────
# Cron jobs
# Use this secret to invoke crons manually:
#   curl -H "Authorization: Bearer $CRON_SECRET" /api/cron/refresh-stats
# ─────────────────────────────────────────────────────────
CRON_SECRET="set-a-strong-random-secret"
CRON_WALLET_CONCURRENCY="2"   # wallets synced in parallel per run
CRON_USER_CONCURRENCY="4"     # users processed in parallel per run

# ─────────────────────────────────────────────────────────
# Optional integrations
# ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=""                  # cron notifications (optional)
MIN_REFERRAL_FOLLOWERS="5"            # min Twitter followers to validate a referral
REACTBITS_LICENSE_KEY=""              # UI component library license (optional)
