generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String
  bio         String?
  avatarUrl   String?
  twitterId   String?  @unique
  privyUserId String?  @unique
  isClaimed   Boolean  @default(false)
  accentColor String?  // hex color like "#FF6B00", null = default cyan #00D4FF
  bannerUrl      String?  // URL to banner image
  followerCount  Int?     // Twitter follower count from fxtwitter
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Referral system
  referredById     String?
  referredBy       User?      @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]     @relation("Referrals")
  givenReferrals   Referral[] @relation("ReferrerReferrals")
  receivedReferral Referral?  @relation("ReferredReferral")

  links            Link[]
  wallets          Wallet[]
  pinnedTrades     PinnedTrade[]
  rankings         UserRanking[]
  tokenDeployments TokenDeployment[]
}

model Link {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  url       String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, order])
}

model Wallet {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  address        String
  chain          String    @default("solana")
  verified       Boolean   @default(false)
  linkedAt       DateTime  @default(now())
  totalPnlUsd    Float?
  winRate        Float?
  totalTrades    Int?
  statsUpdatedAt DateTime?
  isMain         Boolean   @default(false)
  lastSignature  String?   // Helius pagination cursor — only fetch txns newer than this
  lastFetchedAt  DateTime? // When we last fetched transactions
  lastSyncAttemptAt DateTime?
  lastSuccessfulSyncAt DateTime?
  lastSyncStatus String?
  lastSyncError String?
  lastSyncTxnsFetched Int?
  lastSyncTradeRows Int?
  lastSyncEventRows Int?
  syncWarningCode String?
  lastContinuityStatus String?
  lastContinuityIssue String?
  historyCoverageStatus String?
  historyCoverageIssue String?
  historyCoverageUpdatedAt DateTime?
  oldestExactEventAt DateTime?

  trades WalletTrade[]
  tradeEvents WalletTradeEvent[]
  syncAudits WalletSyncAudit[]

  @@unique([userId, address])
  @@index([userId])
}

model WalletSyncAudit {
  id                  String   @id @default(cuid())
  walletId            String
  wallet              Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  syncMode            String
  status              String
  attemptedAt         DateTime
  completedAt         DateTime?
  previousSignature   String?
  newestSignature     String?
  oldestFetchedSignature String?
  txnsFetched         Int      @default(0)
  tradeRows           Int      @default(0)
  eventRows           Int      @default(0)
  pagesFetched        Int      @default(0)
  previousCursorFound Boolean?
  reachedHistoryEnd   Boolean?
  pageLimitReached    Boolean?
  continuityStatus    String?
  continuityIssue     String?
  historyCoverageStatus String?
  historyCoverageIssue String?
  oldestExactEventAt  DateTime?
  warningCode         String?
  error               String?
  createdAt           DateTime @default(now())

  @@index([walletId, attemptedAt])
  @@index([walletId, createdAt])
  @@index([status])
  @@index([continuityStatus])
  @@index([historyCoverageStatus])
}

// Stores accumulated per-token trade PnL — grows each cron run
// This is the source of truth for rankings
model WalletTrade {
  id            String   @id @default(cuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tokenMint     String
  tokenSymbol   String
  tokenName     String?
  tokenImageUrl String?
  buySol        Float    @default(0)
  sellSol       Float    @default(0)
  pnlSol        Float    @default(0)
  tradeCount    Int      @default(0)
  firstTradeAt  DateTime
  lastTradeAt   DateTime
  updatedAt     DateTime @default(now())

  @@unique([walletId, tokenMint])
  @@index([walletId])
  @@index([pnlSol])
}

model WalletTradeEvent {
  id         String   @id @default(cuid())
  walletId   String
  wallet     Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  signature  String
  tokenMint  String
  tokenSymbol String
  tokenName  String?
  tokenImageUrl String?
  type       String
  amountSol  Float
  timestamp  DateTime
  createdAt  DateTime @default(now())

  @@unique([walletId, signature, tokenMint, type])
  @@index([walletId, timestamp])
  @@index([walletId, tokenMint, timestamp])
}

model PinnedTrade {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress   String
  tokenMint       String
  tokenSymbol     String
  tokenName       String?
  tokenImageUrl   String?
  totalPnlPercent Float
  totalPnlSol     Float
  order           Int      @default(0)
  transactions    Json
  pinnedAt        DateTime @default(now())

  @@index([userId, order])
}

model UserRanking {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period    String
  rank      Int?
  pnlUsd    Float
  pnlSol    Float
  winRate   Float
  trades    Int
  updatedAt DateTime @default(now())

  @@unique([userId, period])
  @@index([period, pnlUsd])
  @@index([period, rank])
}

model TokenDeployment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  tokenMint     String   @unique
  tokenSymbol   String
  tokenName     String?
  tokenImageUrl String?
  platform      String   @default("pump.fun")
  status        String   @default("bonding")
  mcapAthUsd    Float?
  holders       Int?
  volumeUsd     Float?
  devPnlSol     Float?
  devPnlUsd     Float?
  deployedAt    DateTime
  updatedAt     DateTime @default(now())

  @@index([userId])
  @@index([walletAddress])
}

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredUserId String    @unique
  referredUser   User      @relation("ReferredReferral", fields: [referredUserId], references: [id])
  status         String    @default("pending") // "pending" | "validated" | "revoked"
  validatedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([referrerId, status])
}
