generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String
  bio         String?
  avatarUrl   String?
  twitterId   String?  @unique
  privyUserId String?  @unique
  isClaimed   Boolean  @default(false)
  accentColor String?  // hex color like "#FF6B00", null = default cyan #00D4FF
  bannerUrl      String?  // URL to banner image
  followerCount  Int?     // Twitter follower count from fxtwitter
  cupChampionSeasons Int[] @default([]) // seasons won as champion
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Referral system
  referredById     String?
  referredBy       User?      @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]     @relation("Referrals")
  givenReferrals   Referral[] @relation("ReferrerReferrals")
  receivedReferral Referral?  @relation("ReferredReferral")

  links            Link[]
  wallets          Wallet[]
  pinnedTrades     PinnedTrade[]
  rankings         UserRanking[]
  tokenDeployments TokenDeployment[]
  deployerSnapshot DeployerSnapshot?

  // Cup tournament participation
  cupParticipations CupParticipant[]

  // Rewards system
  rewardAccount   UserRewardAccount?
  payouts         VaultPayout[]
}

model Link {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  url       String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, order])
}

model Wallet {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  address        String
  chain          String    @default("solana")
  verified       Boolean   @default(false)
  linkedAt       DateTime  @default(now())
  totalPnlUsd    Float?
  winRate        Float?
  totalTrades    Int?
  statsUpdatedAt DateTime?
  isMain         Boolean   @default(false)
  lastSignature  String?   // Helius pagination cursor — only fetch txns newer than this
  lastFetchedAt  DateTime? // When we last fetched transactions
  lastSyncAttemptAt DateTime?
  lastSuccessfulSyncAt DateTime?
  lastSyncStatus String?
  lastSyncError String?
  lastSyncTxnsFetched Int?
  lastSyncTradeRows Int?
  lastSyncEventRows Int?
  syncWarningCode String?
  lastContinuityStatus String?
  lastContinuityIssue String?
  historyCoverageStatus String?
  historyCoverageIssue String?
  historyCoverageUpdatedAt DateTime?
  oldestExactEventAt DateTime?

  trades WalletTrade[]
  tradeEvents WalletTradeEvent[]
  holdings TokenHolding[]
  syncAudits WalletSyncAudit[]

  @@unique([userId, address])
  @@index([userId])
}

model WalletSyncAudit {
  id                  String   @id @default(cuid())
  walletId            String
  wallet              Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  syncMode            String
  status              String
  attemptedAt         DateTime
  completedAt         DateTime?
  previousSignature   String?
  newestSignature     String?
  oldestFetchedSignature String?
  txnsFetched         Int      @default(0)
  tradeRows           Int      @default(0)
  eventRows           Int      @default(0)
  pagesFetched        Int      @default(0)
  previousCursorFound Boolean?
  reachedHistoryEnd   Boolean?
  pageLimitReached    Boolean?
  continuityStatus    String?
  continuityIssue     String?
  historyCoverageStatus String?
  historyCoverageIssue String?
  oldestExactEventAt  DateTime?
  warningCode         String?
  error               String?
  createdAt           DateTime @default(now())

  @@index([walletId, attemptedAt])
  @@index([walletId, createdAt])
  @@index([status])
  @@index([continuityStatus])
  @@index([historyCoverageStatus])
}

// Stores accumulated per-token trade PnL — grows each cron run
// This is the source of truth for rankings
model WalletTrade {
  id            String   @id @default(cuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tokenMint     String
  tokenSymbol   String
  tokenName     String?
  tokenImageUrl String?
  buySol        Float    @default(0)
  sellSol       Float    @default(0)
  pnlSol        Float    @default(0)
  tradeCount    Int      @default(0)
  firstTradeAt  DateTime
  lastTradeAt   DateTime
  updatedAt     DateTime @default(now())

  @@unique([walletId, tokenMint])
  @@index([walletId])
  @@index([pnlSol])
}

model WalletTradeEvent {
  id         String   @id @default(cuid())
  walletId   String
  wallet     Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  signature  String
  tokenMint  String
  tokenSymbol String
  tokenName  String?
  tokenImageUrl String?
  type       String
  amountSol  Float
  timestamp  DateTime
  createdAt  DateTime @default(now())

  @@unique([walletId, signature, tokenMint, type])
  @@index([walletId, timestamp])
  @@index([walletId, tokenMint, timestamp])
}

model TokenHolding {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  tokenMint String
  tokenSymbol String
  tokenName String?
  tokenImageUrl String?
  amount    Float
  valueUsd  Float?

  lastUpdated DateTime @default(now()) @updatedAt

  @@unique([walletId, tokenMint])
  @@index([walletId])
  @@index([walletId, valueUsd])
}

model PinnedTrade {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress   String
  tokenMint       String
  tokenSymbol     String
  tokenName       String?
  tokenImageUrl   String?
  totalPnlPercent Float?
  totalPnlSol     Float
  order           Int      @default(0)
  transactions    Json
  pinnedAt        DateTime @default(now())

  @@index([userId, order])
}

model UserRanking {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period    String
  rank      Int?
  pnlUsd    Float
  pnlSol    Float
  winRate   Float
  trades    Int
  updatedAt DateTime @default(now())

  @@unique([userId, period])
  @@index([period, pnlUsd])
  @@index([period, rank])
}

model TokenDeployment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  tokenMint     String   @unique
  tokenSymbol   String
  tokenName     String?
  tokenImageUrl String?
  platform      String   @default("pump.fun")
  status        String   @default("bonding")
  mcapAthUsd    Float?
  holders       Int?
  volumeUsd     Float?
  devPnlSol     Float?
  devPnlUsd     Float?
  deployedAt    DateTime
  updatedAt     DateTime @default(now())

  @@index([userId])
  @@index([walletAddress])
}

model DeployerSnapshot {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress    String   @unique
  source           String   @default("dune")
  sourceQueryId    Int?
  totalDeployed    Int
  totalMigrated    Int
  graduationRate   Float    @default(0)
  tokens7d         Int      @default(0)
  tokens30d        Int      @default(0)
  validationStatus String   @default("valid")
  validationReason String?
  enrichmentStatus String   @default("pending")
  enrichmentError  String?
  lastEnrichedAt   DateTime?
  localDeploymentCount Int  @default(0)
  syncedAt         DateTime @default(now())
  rawPayload       Json?

  @@index([totalMigrated, tokens7d, totalDeployed])
  @@index([validationStatus, syncedAt])
  @@index([enrichmentStatus, syncedAt])
}

model DeployerSyncAudit {
  id                  String   @id @default(cuid())
  source              String   @default("dune")
  status              String
  attemptedAt         DateTime
  completedAt         DateTime?
  limit               Int?
  skipEnrichment      Boolean  @default(false)
  deployersFetched    Int      @default(0)
  deployersValid      Int      @default(0)
  deployersInvalid    Int      @default(0)
  usersCreated        Int      @default(0)
  usersUpdated        Int      @default(0)
  enrichmentsSucceeded Int     @default(0)
  enrichmentsFailed   Int      @default(0)
  snapshotWarnings    Int      @default(0)
  error               String?
  createdAt           DateTime @default(now())

  @@index([attemptedAt])
  @@index([status, attemptedAt])
}

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredUserId String    @unique
  referredUser   User      @relation("ReferredReferral", fields: [referredUserId], references: [id])
  status         String    @default("pending") // "pending" | "validated" | "revoked"
  validatedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([referrerId, status])
}

// ──────────────────────────────────────────────────────────────
// TRENCHER CUP TOURNAMENT SYSTEM
// ──────────────────────────────────────────────────────────────

model CupSeason {
  id               String   @id @default(cuid())
  name             String   // "Season 1"
  slug             String   @unique // "season-1"
  status           String   @default("draft") // draft, qualifying, groups, r16, qf, sf, final, completed
  qualificationStart DateTime
  qualificationEnd   DateTime
  groupStart         DateTime
  groupEnd           DateTime
  r16Start           DateTime
  r16End             DateTime
  qfStart            DateTime
  qfEnd              DateTime
  sfStart            DateTime
  sfEnd              DateTime
  finalStart         DateTime
  finalEnd           DateTime
  prizePoolUsd       Float    @default(0)
  prizePoolToken     String?  // e.g., "WEB3ME"
  participantCount   Int      @default(0)
  championUserId     String?  // stored as plain field, not FK relation
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  participants     CupParticipant[]
  groups           CupGroup[]
  matches          CupMatch[]
  prizeDistributions CupPrizeDistribution[]
}

model CupParticipant {
  id                  String    @id @default(cuid())
  seasonId            String
  season              CupSeason @relation(fields: [seasonId], references: [id])
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  seed                Int?      // 1-32, assigned at group stage draw
  group               String?   // "A" through "H"
  qualificationPnlUsd Float?
  qualificationPnlSol Float?
  qualificationTrades Int?
  currentRound        String    @default("qualified") // qualified, group, r16, qf, sf, final, eliminated
  eliminatedAt        DateTime?
  eliminatedBy        String?
  finalRank         Int?      // 1-32, set at end
  prizeUsd            Float?
  prizePaid           Boolean @default(false)
  createdAt           DateTime @default(now())

  @@unique([seasonId, userId])
  @@index([seasonId])
  @@index([userId])
  @@index([seasonId, currentRound])
}

model CupGroup {
  id           String    @id @default(cuid())
  seasonId     String
  season       CupSeason @relation(fields: [seasonId], references: [id])
  name         String    // "A" through "H"
  seed         Int       // 0-7 for ordering
  // Participant IDs stored as array (simplified - no FK relations)
  participantIds String[] // array of 4 participant IDs
  createdAt    DateTime  @default(now())

  @@unique([seasonId, name])
  @@index([seasonId])
}

model CupMatch {
  id              String    @id @default(cuid())
  seasonId        String
  season          CupSeason @relation(fields: [seasonId], references: [id])
  round           String    // group, r16, qf, sf, final
  matchNumber     Int       // 1-4 for groups, 1-8 for r16, 1-4 for qf, etc.
  // Participant IDs (simplified - no FK relations to avoid complexity)
  participant1Id  String?
  participant2Id  String?
  // Live PnL tracking during match window
  participant1PnlUsd Float  @default(0)
  participant2PnlUsd Float  @default(0)
  participant1Trades Int    @default(0)
  participant2Trades Int    @default(0)
  // Result
  winnerId        String?
  // Time window
  windowStart     DateTime
  windowEnd       DateTime
  status          String    @default("scheduled") // scheduled, live, completed
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([seasonId, round])
  @@index([seasonId, status])
  @@index([windowEnd])
}

model CupPrizeDistribution {
  id          String   @id @default(cuid())
  seasonId    String
  season      CupSeason @relation(fields: [seasonId], references: [id])
  rank        Int      // 1-32
  title       String   // "Champion", "Runner-up", etc.
  prizeUsd    Float
  percentage  Float    // % of total prize pool
  paid        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([seasonId, rank])
  @@index([seasonId])
}

// ──────────────────────────────────────────────────────────────
// REWARD VAULT & PAYOUT SYSTEM
// ──────────────────────────────────────────────────────────────

model VaultDeposit {
  id          String   @id @default(cuid())
  amountUsd   Float
  amountSol   Float
  source      String   // "trading_fees" | "manual" | "injection"
  description String?
  timestamp   DateTime @default(now())

  @@index([timestamp])
}

model VaultPayout {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountUsd   Float
  amountSol   Float
  type        String   // "weekly_leaderboard" | "cup_prize" | "referral_bonus"
  status      String   @default("pending") // pending, paid, failed
  txSignature String?  // Solana transaction signature
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model UserRewardAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalEarnedUsd Float    @default(0)
  totalPaidUsd   Float    @default(0)
  pendingUsd     Float    @default(0)
  updatedAt      DateTime @updatedAt

  @@index([userId])
}
