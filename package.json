{
  "name": "web3me",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "seed": "prisma db seed",
    "test:e2e": "NEXT_PUBLIC_TEST_AUTH_BYPASS=1 TEST_AUTH_ENABLED=1 npm run build && playwright test",
    "test:e2e:install": "playwright install chromium",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/adapter-pg-worker": "^6.9.0",
    "@prisma/client": "^7.6.0",
    "@prisma/pg-worker": "^6.9.0",
    "@privy-io/react-auth": "^3.18.0",
    "@privy-io/server-auth": "^1.32.5",
    "@react-three/fiber": "^9.5.0",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.183.1",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "gsap": "^3.14.2",
    "html2canvas-pro": "^2.0.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lenis": "^1.3.21",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}